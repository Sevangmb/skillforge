rules_version = '2';

// RÈGLES ULTRA-PERMISSIVES POUR DÉVELOPPEMENT
// ⚠️ A CHANGER EN PRODUCTION ⚠️

service cloud.firestore {
  match /databases/{database}/documents {
    // Accès complet pour tous (développement seulement)
    match /{document=**} {
      allow read, write: if true;
    }
  }
}

// COPIER CES RÈGLES DANS FIREBASE CONSOLE:
